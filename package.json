{
  "name": "multi-tenant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx,js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,vue}\" --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,vue,css,scss,md}\" --check",
    "format:fix": "prettier \"src/**/*.{ts,tsx,js,vue,css,scss,md}\" --write"
  },
  "dependencies": {
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/ui": "^4.1.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
